{
  "manifest_version": 3,
  "name": "Google Photos Delete Helper",
  "version": "1.4.0",
  "description": "Tự động xóa ảnh đã upload sau 5 phút — dùng session Google Photos trong Chrome",
  "permissions": ["storage", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "https://photos.google.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Xóa ảnh Google Photos"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://photos.google.com/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
